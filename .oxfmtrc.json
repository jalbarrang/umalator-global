{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "singleQuote": true,
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "jsxSingleQuote": false,
  "experimentalSortPackageJson": false,
  "endOfLine": "lf",
  "trailingComma": "none",
  "ignorePatterns": [
    "*.png",
    "*.jpg",
    "*.mdb",
    "package-lock.json",
    "bun.lock",
    "yarn.lock",
    "CHANGELOG.md",
    "src/modules/data/json/**/*.json", // Generated game-extract data (recursive: covers gametora/ etc.)
    ".cursor/**", // Vendored skill tooling (impeccable) — not our code to format/lint
    ".agents/**",
    ".pi/**",
    // oxfmt owns code only (matches the lint-staged `*.{ts,tsx}` scope). Rust
    // config, GitHub workflows, and docs keep their own canonical formatting.
    "*.toml",
    "*.yml",
    "*.yaml",
    "*.md"
  ]
}
