{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "singleQuote": true,
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "jsxSingleQuote": false,
  "experimentalSortPackageJson": false,
  "endOfLine": "lf",
  "ignorePatterns": [
    "*.png",
    "*.jpg",
    "*.mdb",
    "package-lock.json",
    "bun.lock",
    "yarn.lock",
    "src/modules/data/json/*.json" // Ignore JSON files that are generated after extracting data from the game
  ]
}
