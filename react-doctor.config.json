{
  "ignore": {
    "files": ["src/components/ui/**", "src/styles/**", "scripts/**", ".pi/**"],
    "rules": [
      "knip/exports",
      "knip/types",
      "knip/files",
      "knip/duplicates",
      "knip/dependencies",
      "knip/enumMembers",
      "knip/classMembers",
      "knip/unlisted"
    ],
    "overrides": [
      {
        "files": ["src/polyfills.ts"],
        "rules": ["react-doctor/js-tosorted-immutable"]
      }
    ]
  }
}
