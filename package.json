{
  "name": "@drekki/torena-sim",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "bun run data:manifest && bun run wasm:build && vite build",
    "preview": "vite preview",
    "typecheck": "tsgo --noEmit",
    "typecheck:legacy": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "oxfmt",
    "knip": "knip --no-config-hints",
    "dupes": "fallow dupes",
    "test": "vitest run",
    "version:current": "bun scripts/master-data/get-current-resource-version.ts",
    "db:fetch": "bun ./scripts/master-data/fetch-master-db.ts",
    "extract:all": "bun scripts/data-extract/extract-all.ts",
    "extract:course-data": "bun scripts/data-extract/extract-course-data.ts",
    "extract:skills": "bun scripts/data-extract/extract-skills.ts",
    "extract:support-cards": "bun scripts/data-extract/extract-support-cards.ts",
    "extract:uma-info": "bun scripts/data-extract/extract-uma-info.ts",
    "fetch:support-events": "bun scripts/data-extract/fetch-support-events.ts",
    "sync:data": "bun scripts/data-extract/sync-gametora.ts",
    "images:support-cards": "bun scripts/data-extract/download-support-card-images.ts",
    "transform:cm-presets": "bun scripts/transform-cm-presets.ts",
    "skill:compare": "bun scripts/run-skill-compare.ts",
    "runner:compare": "bun scripts/run-runner-compare.ts",
    "shadcn:add": "bunx --bun shadcn add",
    "prepare": "husky",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run",
    "changelog:generate": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -s -r 0",
    "wasm:build": "bun scripts/build-wasm.ts",
    "check:worker-bundles": "bun scripts/check-worker-bundles.ts",
    "data:manifest": "bun scripts/generate-data-manifest.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jalbarrang/torena-sim.git"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/noto-sans-jp": "^5.2.10",
    "@posthog/react": "^1.9.1",
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.25",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "d3": "^7.9.0",
    "date-fns": "^4.2.1",
    "dayjs": "^1.11.20",
    "es-toolkit": "^1.46.1",
    "html-to-image": "^1.11.13",
    "i18next": "^25.10.10",
    "immer": "^11.1.8",
    "lucide-react": "^0.555.0",
    "lz4js": "^0.2.0",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.376.0",
    "prando": "^6.0.1",
    "react": "^19.2.6",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.6",
    "react-hotkeys-hook": "^5.3.2",
    "react-i18next": "^16.6.6",
    "react-router": "^7.15.1",
    "recharts": "2.15.4",
    "shadcn": "^3.8.5",
    "sonner": "^2.0.7",
